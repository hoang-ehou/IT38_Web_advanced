@{
    ViewData["Title"] = "Book Appointment";
}

<h2>@ViewData["Title"]</h2>

<div class="row">
    <div class="col-md-6">
        <form id="bookingForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label for="departmentId" class="control-label">Department</label>
                <select id="departmentId" class="form-control">
                    <option value="">-- Select Department --</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label for="doctorId" class="control-label">Doctor</label>
                <select id="doctorId" class="form-control" disabled>
                    <option value="">-- Select Doctor --</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label for="appointmentDate" class="control-label">Date & Time</label>
                <input id="appointmentDate" type="datetime-local" class="form-control" />
                <span id="dateError" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label for="notes" class="control-label">Notes (optional)</label>
                <textarea id="notes" class="form-control" rows="3"></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Book Appointment</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
        <div id="message" class="mt-3"></div>
    </div>
</div>

@section Scripts {
    <script>
        const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

        // Load departments on page load
        fetch('/Api/Department/GetAll')
            .then(r => r.json())
            .then(departments => {
                const deptSelect = document.getElementById('departmentId');
                departments.forEach(d => {
                    const opt = document.createElement('option');
                    opt.value = d.id;
                    opt.textContent = d.name;
                    deptSelect.appendChild(opt);
                });
            });

        // When department changes, load doctors
        document.getElementById('departmentId').addEventListener('change', function() {
            const deptId = this.value;
            const doctorSelect = document.getElementById('doctorId');
            doctorSelect.disabled = !deptId;
            doctorSelect.innerHTML = '<option value="">-- Select Doctor --</option>';

            if (deptId) {
                fetch('/Api/Doctors/GetAvailableDoctors?departmentId=' + deptId)
                    .then(r => r.json())
                    .then(doctors => {
                        doctors.forEach(d => {
                            const opt = document.createElement('option');
                            opt.value = d.id;
                            opt.textContent = `${d.name} - ${d.specialization}${d.fee ? ' ($' + d.fee + ')' : ''}`;
                            doctorSelect.appendChild(opt);
                        });
                    });
            }
        });

        // Set minimum datetime to now
        const now = new Date();
        now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
        document.getElementById('appointmentDate').min = now.toISOString().slice(0, 16);

        // Handle form submit
        document.getElementById('bookingForm').addEventListener('submit', function(e) {
            e.preventDefault();

            const doctorId = document.getElementById('doctorId').value;
            const appointmentDate = document.getElementById('appointmentDate').value;
            const notes = document.getElementById('notes').value;

            if (!doctorId || !appointmentDate) {
                showMessage('Please select doctor and date/time', 'danger');
                return;
            }

            fetch('/Api/Appointment/Create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': antiForgeryToken
                },
                body: JSON.stringify({
                    doctorId: doctorId,
                    appointmentDate: appointmentDate,
                    notes: notes
                })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    showMessage('<div class="alert alert-success">' + data.message + '</div>', 'success');
                    setTimeout(() => window.location.href = '/Appointment', 1500);
                } else {
                    showMessage('<div class="alert alert-danger">' + data.message + '</div>', 'danger');
                }
            })
            .catch(err => {
                showMessage('<div class="alert alert-danger">Error booking appointment</div>', 'danger');
            });
        });

        function showMessage(html, type) {
            const msgDiv = document.getElementById('message');
            msgDiv.innerHTML = html;
            msgDiv.className = 'mt-3';
        }
    </script>
}
