@model MedicalBooking.Models.Appointment

@{
    ViewData["Title"] = "Appointment Details";
}

<h2>@ViewData["Title"]</h2>

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-3">Patient</dt>
            <dd class="col-sm-9">@Model.Patient?.FullName (@Model.Patient?.Email)</dd>

            <dt class="col-sm-3">Doctor</dt>
            <dd class="col-sm-9">@Model.Doctor?.FullName (@Model.Doctor?.Specialization) - @Model.Doctor?.Department?.Name</dd>

            <dt class="col-sm-3">Appointment Time</dt>
            <dd class="col-sm-9">@Model.AppointmentDate.ToString("yyyy-MM-dd HH:mm")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                <span class="badge bg-@(Model.Status == "Confirmed" ? "success" : Model.Status == "Cancelled" ? "danger" : "warning")">
                    @Model.Status
                </span>
            </dd>

            <dt class="col-sm-3">Notes</dt>
            <dd class="col-sm-9">@(Model.Notes ?? "None")</dd>

            <dt class="col-sm-3">Created At</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
        </dl>

        @if (Model.MedicalRecord != null)
        {
            <hr />
            <h4>Medical Record</h4>
            <dl class="row">
                <dt class="col-sm-3">Diagnosis</dt>
                <dd class="col-sm-9">@(Model.MedicalRecord.Diagnosis ?? "None")</dd>
                <dt class="col-sm-3">Prescription</dt>
                <dd class="col-sm-9">@(Model.MedicalRecord.Prescription ?? "None")</dd>
                <dt class="col-sm-3">Notes</dt>
                <dd class="col-sm-9">@(Model.MedicalRecord.Notes ?? "None")</dd>
            </dl>
        }

        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>
